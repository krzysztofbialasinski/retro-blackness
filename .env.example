# Backend service (src/main.luau)
RB_ROBLOX_API_BASE_URL=https://apis.roblox.com

# Roblox Open Cloud API key. Create at https://create.roblox.com/dashboard/credentials with at
# least Users API -> Read scope (add Universes API / Place Management -> Write too if you also
# use the publish pipeline below, scoped to the same universe/place as RB_UNIVERSE_ID/RB_PLACE_ID).
RB_ROBLOX_OPEN_CLOUD_API_KEY=

# Shared secret for verifying inbound webhook signatures (HMAC-SHA256, see
# src/infrastructure/webhooks/signature_verifier.luau). Not issued by Roblox -- generate your own
# (e.g. `openssl rand -hex 32`) and configure the same value on the in-game Luau sender side.
RB_ROBLOX_WEBHOOK_SECRET=

RB_PORT=8080

# Publish pipeline only (scripts/publish.luau)
# Both IDs identify the target Roblox experience/place. Find them at
# https://create.roblox.com/dashboard/creations -> your experience -> Basic Info, or in the
# place configuration page's URL.
RB_UNIVERSE_ID=
RB_PLACE_ID=
